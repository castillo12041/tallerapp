# ============================================================
# TALLER INSPECCIÓN — Backend FastAPI
# Variables de entorno
# ============================================================
# Copiar este archivo a .env y completar los valores.
# NUNCA commitear .env ni archivos con secretos reales.
# Generar claves seguras con: openssl rand -hex 32
# ============================================================

# ============================================================
# Aplicación
# ============================================================
ENVIRONMENT=development
# Valores válidos: development | staging | production

DEBUG=false
# Nunca true en producción

PROJECT_NAME="Taller Inspección API"
VERSION="0.1.0"

LOG_LEVEL=INFO
# Valores válidos: DEBUG | INFO | WARNING | ERROR | CRITICAL

# ============================================================
# URLs
# ============================================================
PUBLIC_BASE_URL=https://tallerinspeccion.tapsolutions.cl
# URL base pública usada en tokens QR, links de presupuesto, etc.

# ============================================================
# CORS — Orígenes permitidos
# Separados por coma. En producción: solo dominios reales.
# ============================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5000

# Producción:
# ALLOWED_ORIGINS=https://tallerinspeccion.tapsolutions.cl,https://admin.tallerinspeccion.tapsolutions.cl,https://cliente.tallerinspeccion.tapsolutions.cl

# ============================================================
# Google Cloud Platform
# ============================================================
GCP_PROJECT_ID=taller-85514

USE_SECRET_MANAGER=false
# En producción (Cloud Run): true — las credenciales se leen desde Secret Manager
# En desarrollo local: false — se usan las variables de este .env

# ============================================================
# Firebase Admin SDK
# ============================================================
FIREBASE_PROJECT_ID=taller-85514

FIREBASE_CREDENTIALS_PATH=firebase_credentials.json
# Ruta al archivo JSON de Service Account.
# Descargar desde: Firebase Console > Configuración > Cuentas de servicio
# NUNCA commitear este archivo.
# En Cloud Run con USE_SECRET_MANAGER=true, esta variable es ignorada.

FIREBASE_STORAGE_BUCKET=taller-85514.appspot.com
# Bucket de Firebase Storage para PDFs, imágenes y logos.

# ============================================================
# JWT interno
# Complementa Firebase Auth — NO lo reemplaza.
# Genera con: openssl rand -hex 32
# ============================================================
JWT_SECRET_KEY=CAMBIAR-POR-CLAVE-SEGURA-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================
# HMAC — Tokens públicos
# Usado para firmar URLs de QR, informes e informes de presupuesto.
# Genera con: openssl rand -hex 32
# DEBE ser diferente a JWT_SECRET_KEY.
# ============================================================
HMAC_SECRET_KEY=CAMBIAR-POR-OTRA-CLAVE-SEGURA-openssl-rand-hex-32
QR_TOKEN_EXPIRY_DAYS=365

# ============================================================
# Rate Limiting
# Por IP, ventana deslizante. Ajustar según métricas de producción.
# ============================================================
RATE_LIMIT_CALLS=60
RATE_LIMIT_PERIOD_SECONDS=60
RATE_LIMIT_AUTH_CALLS=10

# ============================================================
# Email — SendGrid (recomendado) o SMTP
# Usar SendGrid para producción. SMTP como alternativa.
# ============================================================

# SendGrid
SENDGRID_API_KEY=
# Obtener en: https://app.sendgrid.com/settings/api_keys

SENDGRID_FROM_EMAIL=noreply@tallerinspeccion.tapsolutions.cl
SENDGRID_FROM_NAME=Taller Inspección

# SMTP alternativo (dejar vacío si se usa SendGrid)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# ============================================================
# WhatsApp — Twilio
# Requiere plan Premium o superior.
# ============================================================
TWILIO_ACCOUNT_SID=
# Obtener en: https://console.twilio.com

TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Número en formato: whatsapp:+14155238886

# ============================================================
# PDF
# ============================================================
PDF_MAX_WORKERS=2
PDF_TIMEOUT_SECONDS=30

# ============================================================
# Monitoring — Sentry
# Opcional pero recomendado para producción.
# ============================================================
SENTRY_DSN=
# Obtener en: https://sentry.io

# ============================================================
# Workers internos (Cloud Run — Fase 19)
# Dejar vacío hasta que los workers estén desplegados.
# ============================================================
WORKERS_URL=
WORKERS_API_KEY=
