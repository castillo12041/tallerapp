# ============================================================
# TALLER INSPECCIÓN — Raíz del monorepo
# ============================================================
# Este archivo documenta las variables de entorno del proyecto.
# Cada componente tiene su propio .env.example:
#
#   backend/.env.example          → FastAPI (variables de servidor)
#   apps/cliente/.env.example     → Flutter Web — Portal Cliente
#   apps/web_admin/.env.example   → Flutter Web — Panel Admin
#   apps/mobile/.env.example      → Flutter Android + iOS
#
# IMPORTANTE: Las apps Flutter NO usan archivos .env en runtime.
# Sus variables se pasan en compilación con --dart-define.
# Ver docs/ENVIRONMENT_VARIABLES.md para detalles completos.
# ============================================================

# ============================================================
# Scripts de desarrollo (Makefile / scripts/dev.sh)
# Estas variables configuran los scripts de automatización.
# ============================================================

# Puerto del backend local
BACKEND_PORT=8000

# Ambiente activo
ENVIRONMENT=development
