# ============================================================
# TALLER INSPECCIÓN — App Mobile (Flutter Android + iOS)
# apps/mobile — Variables de compilación Flutter
# ============================================================
# Flutter NO lee archivos .env en tiempo de ejecución.
# En mobile las variables se pasan con --dart-define o
# con --dart-define-from-file en CI/CD.
#
# MODO DE USO — Desarrollo Android:
#   flutter run -d android \
#     --dart-define=API_BASE_URL=http://10.0.2.2:8000 \
#     --dart-define=ENVIRONMENT=development
#
# NOTA: En el emulador Android, localhost del host es 10.0.2.2
# En dispositivo físico: usar la IP local de tu máquina (ej: 192.168.1.x)
#
# MODO DE USO — Producción:
#   flutter build apk \
#     --dart-define-from-file=.dart-defines.json
# ============================================================

API_BASE_URL=http://10.0.2.2:8000
# Emulador Android: http://10.0.2.2:8000
# Dispositivo físico: http://<IP_LOCAL>:8000
# Staging:           https://api-staging.tallerinspeccion.tapsolutions.cl
# Producción:        https://api.tallerinspeccion.tapsolutions.cl

ENVIRONMENT=development

APP_VERSION=1.0.0

# ============================================================
# Firebase Mobile Config
# Android: descargado como google-services.json (apps/mobile/android/app/)
# iOS: descargado como GoogleService-Info.plist (apps/mobile/ios/Runner/)
# NUNCA commitear estos archivos con valores reales de producción
# si el repositorio es público.
# ============================================================
FIREBASE_PROJECT_ID=taller-85514

# ============================================================
# Offline Sync (Drift + SQLite)
# ============================================================
DB_NAME=taller_local.db
SYNC_INTERVAL_SECONDS=30
MAX_SYNC_RETRY=3
