# ============================================================
# TALLER INSPECCIÓN — Portal del Cliente (Flutter Web)
# Variables de entorno para compilación Flutter
# ============================================================
# Flutter NO lee archivos .env en tiempo de ejecución.
# Estas variables se pasan en tiempo de compilación con --dart-define.
#
# MODO DE USO — Desarrollo:
#   flutter run -d chrome \
#     --dart-define=API_BASE_URL=http://localhost:8000 \
#     --dart-define=ENVIRONMENT=development
#
# MODO DE USO — Producción:
#   flutter build web \
#     --dart-define=API_BASE_URL=https://api.tallerinspeccion.tapsolutions.cl \
#     --dart-define=ENVIRONMENT=production
#
# ALTERNATIVA — Archivo de dart-defines (recomendado para CI):
#   flutter build web --dart-define-from-file=.dart-defines.json
#   Ver: apps/cliente/.dart-defines.example.json
# ============================================================

# ============================================================
# API
# ============================================================
API_BASE_URL=http://localhost:8000
# Desarrollo:   http://localhost:8000
# Staging:      https://api-staging.tallerinspeccion.tapsolutions.cl
# Producción:   https://api.tallerinspeccion.tapsolutions.cl

# ============================================================
# Aplicación
# ============================================================
ENVIRONMENT=development
# Valores válidos: development | staging | production

APP_VERSION=1.0.0

# ============================================================
# Firebase (para Analytics y Performance en web)
# Estos valores NO son secretos — van en el bundle de Flutter Web.
# Obtener desde: Firebase Console > Configuración del proyecto > Web
# ============================================================
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=taller-85514.firebaseapp.com
FIREBASE_PROJECT_ID=taller-85514
FIREBASE_STORAGE_BUCKET=taller-85514.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
